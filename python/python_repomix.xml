    position_lr: float = 0.50
    size_lr: float = 0.30
    rotation_lr: float = 0.02
    alpha_lr: float = 0.01
    color_decay_steps: int = 0
    position_decay_steps: int = 0
    size_decay_steps: int = 0
    alpha_decay_steps: int = 0
